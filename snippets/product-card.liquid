{% doc %}
  Renders a product card with image, title, price, badges, and quick-add to cart.

  @param {product} product - The product to render
  @param {boolean} [show_vendor] - Whether to display the vendor name
  @param {boolean} [show_price] - Whether to display the price (default: true)
  @param {boolean} [show_add_to_cart] - Whether to show the add to cart button (default: true)

  @example
  {% render 'product-card', product: product %}
  {% render 'product-card', product: product, show_vendor: true, show_add_to_cart: true %}
{% enddoc %}

{%- liquid
  assign show_vendor = show_vendor | default: false
  assign show_price = show_price | default: true
  assign show_add_to_cart = show_add_to_cart | default: true
  assign current_variant = product.selected_or_first_available_variant
  assign is_on_sale = false
  if current_variant.compare_at_price > current_variant.price
    assign is_on_sale = true
  endif
-%}

<article class="product-card" data-product-id="{{ product.id }}">
  <a href="{{ product.url }}" class="product-card__media" tabindex="-1" aria-hidden="true">
    <div class="product-card__image-wrapper">
      {%- if product.featured_image -%}
        {{
          product.featured_image
          | image_url: width: 600
          | image_tag:
            loading: 'lazy',
            class: 'product-card__image product-card__image--primary',
            alt: product.featured_image.alt | escape
        }}
        {%- if product.images[1] -%}
          {{
            product.images[1]
            | image_url: width: 600
            | image_tag:
              loading: 'lazy',
              class: 'product-card__image product-card__image--secondary',
              alt: product.images[1].alt | escape
          }}
        {%- endif -%}
      {%- else -%}
        {%- assign placeholder_index = product.id | modulo: 6 | plus: 1 -%}
        {{ 'product-' | append: placeholder_index | placeholder_svg_tag: 'product-card__image product-card__image--placeholder' }}
      {%- endif -%}
    </div>

    <div class="product-card__badges">
      {%- unless product.available -%}
        <span class="product-card__badge product-card__badge--sold-out">{{ 'products.badge.sold_out' | t }}</span>
      {%- else -%}
        {%- if is_on_sale -%}
          <span class="product-card__badge product-card__badge--sale">{{ 'products.badge.sale' | t }}</span>
        {%- endif -%}
        {%- if product.tags contains 'new' or product.tags contains 'New' -%}
          <span class="product-card__badge product-card__badge--new">{{ 'products.badge.new' | t }}</span>
        {%- endif -%}
      {%- endunless -%}
    </div>
  </a>

  <div class="product-card__info">
    {%- if show_vendor -%}
      <p class="product-card__vendor">{{ product.vendor | escape }}</p>
    {%- endif -%}

    <a href="{{ product.url }}" class="product-card__title-link">
      <h3 class="product-card__title">{{ product.title | escape }}</h3>
    </a>

    {%- if show_price -%}
      <div class="product-card__price">
        {%- if is_on_sale -%}
          <s class="product-card__price-compare">{{ current_variant.compare_at_price | money }}</s>
          <span class="product-card__price-sale">{{ current_variant.price | money }}</span>
        {%- else -%}
          <span class="product-card__price-regular">
            {%- if product.price_varies -%}
              {{ 'products.price_from' | t }} {{ product.price_min | money }}
            {%- else -%}
              {{ current_variant.price | money }}
            {%- endif -%}
          </span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if show_add_to_cart -%}
      {%- if product.available -%}
        {%- form 'product', product, class: 'product-card__form' -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}">
          <button
            type="submit"
            class="product-card__add-btn"
            aria-label="{{ 'products.quick_add' | t }}: {{ product.title | escape }}"
          >
            {{ 'products.quick_add' | t }}
          </button>
        {%- endform -%}
      {%- else -%}
        <button class="product-card__add-btn product-card__add-btn--disabled" disabled>
          {{ 'products.sold_out' | t }}
        </button>
      {%- endif -%}
    {%- endif -%}

    <button
      type="button"
      class="product-card__compare-btn"
      data-compare-toggle
      data-product-handle="{{ product.handle }}"
      aria-pressed="false"
      aria-label="{{ 'products.compare.add_label' | t: title: product.title | escape }}"
    >
      <svg class="compare-icon-add" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="1" y="4.5" width="6" height="7.5" rx="1"/>
        <rect x="6" y="1" width="6" height="7.5" rx="1"/>
      </svg>
      <svg class="compare-icon-check" width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="1.5 6.5 5 10 11.5 3"/>
      </svg>
      <span data-compare-text>{{ 'products.compare.add' | t }}</span>
    </button>
  </div>
</article>

{% stylesheet %}
  .product-card {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .product-card__media {
    position: relative;
    display: block;
    text-decoration: none;
    border-radius: 0.75rem;
    overflow: hidden;
  }

  .product-card__image-wrapper {
    aspect-ratio: 1 / 1;
    background-color: #f5f5f0;
    overflow: hidden;
    position: relative;
  }

  .product-card__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease, opacity 0.3s ease;
    display: block;
  }

  .product-card__image--secondary {
    opacity: 0;
  }

  .product-card__media:hover .product-card__image--primary:not(.product-card__image--placeholder) {
    opacity: 0;
    transform: scale(1.03);
  }

  .product-card__media:hover .product-card__image--secondary {
    opacity: 1;
  }

  .product-card__badges {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    z-index: 2;
  }

  .product-card__badge {
    display: inline-block;
    padding: 0.25rem 0.5rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    border-radius: 3px;
    line-height: 1;
  }

  .product-card__badge--sale {
    background: #1a1a1a;
    color: #fff;
  }

  .product-card__badge--new {
    background: #2d7a3a;
    color: #fff;
  }

  .product-card__badge--sold-out {
    background: rgba(0, 0, 0, 0.5);
    color: #fff;
  }

  .product-card__info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .product-card__vendor {
    font-size: 0.7rem;
    color: #999;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.07em;
  }

  .product-card__title-link {
    text-decoration: none;
    color: inherit;
  }

  .product-card__title {
    font-size: 0.9375rem;
    font-weight: 500;
    margin: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-card__title-link:hover .product-card__title {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .product-card__price {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    align-items: baseline;
    font-size: 0.9375rem;
    margin-top: 0.1rem;
  }

  .product-card__price-compare {
    color: #bbb;
    font-size: 0.8125rem;
    text-decoration: line-through;
  }

  .product-card__price-sale {
    color: #c00;
    font-weight: 600;
  }

  .product-card__form {
    margin-top: 0.625rem;
  }

  .product-card__add-btn {
    width: 100%;
    padding: 0.625rem 1rem;
    border: 1px solid rgba(0, 0, 0, 0.18);
    background: transparent;
    cursor: pointer;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    border-radius: var(--style-border-radius-inputs);
    transition: background-color var(--transition-base), color var(--transition-base), border-color var(--transition-base);
    color: var(--color-foreground);
  }

  .product-card__add-btn:hover:not(:disabled) {
    background-color: var(--color-accent);
    color: var(--color-accent-foreground);
    border-color: var(--color-accent);
  }

  .product-card__add-btn--disabled {
    opacity: 0.38;
    cursor: not-allowed;
  }
{% endstylesheet %}
