<div
  class="newsletter"
  style="
    --newsletter-bg: {{ section.settings.background_color }};
    --newsletter-color: {{ section.settings.text_color }};
  "
>
  <div class="newsletter__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="newsletter__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    {%- if section.settings.body_text != blank -%}
      <p class="newsletter__body">{{ section.settings.body_text | escape }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter__form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      {%- if form.posted_successfully? -%}
        <p class="newsletter__success">{{ 'sections.newsletter.success' | t }}</p>
      {%- else -%}
        <div class="newsletter__field">
          <label for="newsletter-email-{{ section.id }}" class="visually-hidden">
            {{ 'sections.newsletter.email_placeholder' | t }}
          </label>
          <input
            type="email"
            id="newsletter-email-{{ section.id }}"
            name="contact[email]"
            placeholder="{{ 'sections.newsletter.email_placeholder' | t }}"
            class="newsletter__input"
            required
            autocomplete="email"
          >
          <button type="submit" class="newsletter__btn">
            {{ 'sections.newsletter.submit' | t }}
          </button>
        </div>

        {%- if form.errors -%}
          <p class="newsletter__error">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {%- endif -%}
    {%- endform -%}
  </div>
</div>

{% stylesheet %}
  .newsletter {
    background-color: var(--newsletter-bg);
    color: var(--newsletter-color);
    padding: 5rem 0;
  }

  .newsletter__inner {
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .newsletter__heading {
    font-size: clamp(1.5rem, 3vw, 2.125rem);
    font-weight: 700;
    margin: 0;
  }

  .newsletter__body {
    opacity: 0.7;
    font-size: 1rem;
    line-height: 1.65;
    margin: 0;
    max-width: 38ch;
  }

  .newsletter__form {
    width: 100%;
    max-width: 30rem;
    margin-top: 0.5rem;
  }

  .newsletter__field {
    display: flex;
    gap: 0;
    width: 100%;
    border: 1.5px solid currentColor;
    border-radius: var(--style-border-radius-inputs);
    overflow: hidden;
  }

  .newsletter__input {
    flex: 1;
    padding: 0.875rem 1.125rem;
    border: none;
    background: transparent;
    color: inherit;
    font-size: 0.9375rem;
    min-width: 0;
  }

  .newsletter__input::placeholder {
    opacity: 0.45;
  }

  .newsletter__input:focus {
    outline: none;
  }

  .newsletter__btn {
    padding: 0.875rem 1.5rem;
    background: currentColor;
    color: var(--newsletter-bg);
    border: none;
    font-size: 0.875rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    cursor: pointer;
    transition: opacity var(--transition-base);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .newsletter__btn:hover {
    opacity: 0.8;
  }

  .newsletter__success {
    font-size: 0.9375rem;
    font-weight: 500;
    color: #2d7a3a;
  }

  .newsletter__error {
    font-size: 0.875rem;
    margin-top: 0.5rem;
    color: #c00;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 480px) {
    .newsletter__field {
      flex-direction: column;
      border-radius: 0;
      border: none;
      gap: 0.5rem;
    }

    .newsletter__input {
      border: 1.5px solid currentColor;
      border-radius: var(--style-border-radius-inputs);
    }

    .newsletter__btn {
      width: 100%;
      border-radius: var(--style-border-radius-inputs);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#f5f5f0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.foreground",
      "default": "#1a1a1a"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Stay in the loop"
    },
    {
      "type": "text",
      "id": "body_text",
      "label": "t:labels.text",
      "default": "Get exclusive offers, new arrivals, and insider news delivered to your inbox."
    }
  ],
  "presets": [
    {
      "name": "t:general.newsletter"
    }
  ]
}
{% endschema %}
