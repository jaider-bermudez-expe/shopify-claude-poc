<section class="blog-landing">

  <header class="blog-landing__header">
    <p class="blog-landing__eyebrow">{{ 'sections.blog_landing.eyebrow' | t }}</p>
    <h1 class="blog-landing__title">
      {%- if section.settings.heading != blank -%}
        {{ section.settings.heading }}
      {%- else -%}
        {{ blog.title }}
      {%- endif -%}
    </h1>
    {%- if section.settings.subheading != blank -%}
      <p class="blog-landing__subtitle">{{ section.settings.subheading }}</p>
    {%- endif -%}
  </header>

  {%- paginate blog.articles by section.settings.articles_per_page -%}

    {%- if section.settings.show_featured and paginate.current_page == 1 and blog.articles.size > 0 -%}
      {%- assign featured = blog.articles.first -%}
      <div class="blog-landing__featured">
        <a href="{{ featured.url }}" class="blog-landing__featured-link">
          <div class="blog-landing__featured-image">
            {%- if featured.image -%}
              {%- assign featured_alt = featured.image.alt | default: featured.title | escape -%}
              {{
                featured.image
                | image_url: width: 1400
                | image_tag:
                  loading: 'eager',
                  class: 'blog-landing__featured-img',
                  alt: featured_alt
              }}
            {%- else -%}
              <div class="blog-landing__featured-placeholder">
                {{ 'image' | placeholder_svg_tag: 'blog-landing__placeholder-svg' }}
              </div>
            {%- endif -%}
          </div>
          <div class="blog-landing__featured-content">
            {%- if featured.tags.size > 0 -%}
              <span class="blog-landing__tag">{{ featured.tags.first }}</span>
            {%- endif -%}
            <h2 class="blog-landing__featured-title">{{ featured.title }}</h2>
            {%- if featured.excerpt != blank -%}
              <p class="blog-landing__featured-excerpt">{{ featured.excerpt | strip_html | truncate: 220 }}</p>
            {%- endif -%}
            <div class="blog-landing__meta">
              <span class="blog-landing__author-avatar" aria-hidden="true">{{ featured.author | slice: 0 | upcase }}</span>
              <span>{{ featured.author }}</span>
              <span class="blog-landing__dot" aria-hidden="true">&middot;</span>
              <time datetime="{{ featured.published_at | date: '%Y-%m-%d' }}">
                {{ featured.published_at | date: '%B %d, %Y' }}
              </time>
            </div>
          </div>
        </a>
      </div>
    {%- endif -%}

    <div class="blog-landing__grid" style="--columns: {{ section.settings.columns_desktop }}">
      {%- for article in blog.articles -%}
        {%- if section.settings.show_featured and paginate.current_page == 1 and forloop.first -%}
          {%- continue -%}
        {%- endif -%}

        {%- assign read_time = article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
        {%- assign card_alt = article.image.alt | default: article.title | escape -%}

        <article class="blog-card">
          <a href="{{ article.url }}" class="blog-card__image-link" tabindex="-1" aria-hidden="true">
            <div class="blog-card__image-wrap">
              {%- if article.image -%}
                {{
                  article.image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    class: 'blog-card__image',
                    alt: card_alt
                }}
              {%- else -%}
                <div class="blog-card__image-placeholder">
                  {{ 'image' | placeholder_svg_tag: 'blog-card__placeholder-svg' }}
                </div>
              {%- endif -%}
              {%- if article.tags.size > 0 -%}
                <span class="blog-card__tag">{{ article.tags.first }}</span>
              {%- endif -%}
            </div>
          </a>

          <div class="blog-card__body">
            <div class="blog-card__meta">
              <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                {{ article.published_at | date: '%b %d, %Y' }}
              </time>
              {%- if section.settings.show_read_time -%}
                <span aria-hidden="true">&middot;</span>
                <span>{{ read_time }} {{ 'sections.blog_landing.min_read' | t }}</span>
              {%- endif -%}
            </div>

            <h2 class="blog-card__title">
              <a href="{{ article.url }}">{{ article.title }}</a>
            </h2>

            {%- if article.excerpt != blank -%}
              <p class="blog-card__excerpt">{{ article.excerpt | strip_html | truncate: 140 }}</p>
            {%- endif -%}

            <div class="blog-card__footer">
              <div class="blog-card__author">
                <span class="blog-card__author-avatar" aria-hidden="true">{{ article.author | slice: 0 | upcase }}</span>
                <span class="blog-card__author-name">{{ article.author }}</span>
              </div>
              <a href="{{ article.url }}" class="blog-card__read-more" aria-label="{{ 'sections.blog_landing.read_more_label' | t: title: article.title }}">
                {{ 'sections.blog_landing.read_more' | t }}
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M1 7h12M7 1l6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div class="blog-landing__pagination">
        {{ paginate | default_pagination }}
      </div>
    {%- endif -%}

  {%- endpaginate -%}

</section>

{% stylesheet %}
  .blog-landing {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem 5rem;
  }

  /* ── Header ─────────────────────────────────── */
  .blog-landing__header {
    text-align: center;
    padding: 4rem 0 3rem;
    border-bottom: 1px solid #e8e5e0;
    margin-bottom: 3rem;
  }

  .blog-landing__eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-accent, #8b7355);
    margin: 0 0 0.75rem;
  }

  .blog-landing__title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0 0 1rem;
  }

  .blog-landing__subtitle {
    font-size: 1.1rem;
    color: #6b6b6b;
    max-width: 52ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* ── Featured ────────────────────────────────── */
  .blog-landing__featured {
    margin-bottom: 3rem;
  }

  .blog-landing__featured-link {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    text-decoration: none;
    color: inherit;
    background: #fafaf8;
    border-radius: 1rem;
    overflow: hidden;
    border: 1px solid #ede9e3;
  }

  .blog-landing__featured-image {
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .blog-landing__featured-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.45s ease;
    display: block;
  }

  .blog-landing__featured-link:hover .blog-landing__featured-img {
    transform: scale(1.04);
  }

  .blog-landing__featured-placeholder {
    width: 100%;
    height: 100%;
    background: #ede9e3;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-landing__placeholder-svg {
    width: 64px;
    height: 64px;
    opacity: 0.25;
  }

  .blog-landing__featured-content {
    padding: 2.75rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .blog-landing__tag {
    display: inline-block;
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent, #8b7355);
    background: rgba(139, 115, 85, 0.1);
    padding: 0.25rem 0.65rem;
    border-radius: 2rem;
    margin-bottom: 1rem;
  }

  .blog-landing__featured-title {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 1rem;
  }

  .blog-landing__featured-link:hover .blog-landing__featured-title {
    text-decoration: underline;
  }

  .blog-landing__featured-excerpt {
    color: #5c5c5c;
    line-height: 1.65;
    margin-bottom: 1.5rem;
    flex: 1;
  }

  .blog-landing__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: #888;
  }

  .blog-landing__meta .blog-landing__author-avatar {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent, #8b7355);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .blog-landing__dot {
    opacity: 0.4;
  }

  /* ── Grid ────────────────────────────────────── */
  .blog-landing__grid {
    display: grid;
    grid-template-columns: repeat(var(--columns, 3), 1fr);
    gap: 1.75rem;
    margin-bottom: 3rem;
  }

  /* ── Cards ───────────────────────────────────── */
  .blog-card {
    display: flex;
    flex-direction: column;
    border-radius: 0.75rem;
    overflow: hidden;
    background: #fff;
    border: 1px solid #ede9e3;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .blog-card:hover {
    box-shadow: 0 8px 28px rgba(0, 0, 0, 0.08);
    transform: translateY(-2px);
  }

  .blog-card__image-wrap {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    position: relative;
  }

  .blog-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .blog-card:hover .blog-card__image {
    transform: scale(1.04);
  }

  .blog-card__image-placeholder {
    width: 100%;
    height: 100%;
    background: #f0ede8;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .blog-card__placeholder-svg {
    width: 40px;
    height: 40px;
    opacity: 0.25;
  }

  .blog-card__tag {
    position: absolute;
    top: 0.65rem;
    left: 0.65rem;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: #fff;
    color: #333;
    padding: 0.2rem 0.55rem;
    border-radius: 2rem;
    line-height: 1.6;
  }

  .blog-card__body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 1.25rem;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.75rem;
    color: #aaa;
    margin-bottom: 0.55rem;
  }

  .blog-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__title a {
    color: inherit;
    text-decoration: none;
  }

  .blog-card__title a:hover {
    text-decoration: underline;
  }

  .blog-card__excerpt {
    font-size: 0.875rem;
    color: #666;
    line-height: 1.55;
    margin: 0 0 1rem;
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid #f0ede8;
    margin-top: auto;
  }

  .blog-card__author {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .blog-card__author-avatar {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 50%;
    background: var(--color-accent, #8b7355);
    color: #fff;
    font-size: 0.65rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .blog-card__author-name {
    font-size: 0.8rem;
    color: #555;
  }

  .blog-card__read-more {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-accent, #8b7355);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .blog-card__read-more:hover {
    gap: 0.5rem;
  }

  /* ── Pagination ──────────────────────────────── */
  .blog-landing__pagination {
    display: flex;
    justify-content: center;
    padding-top: 1.5rem;
    border-top: 1px solid #e8e5e0;
  }

  /* ── Responsive ──────────────────────────────── */
  @media (max-width: 900px) {
    .blog-landing__featured-link {
      grid-template-columns: 1fr;
    }

    .blog-landing__featured-image {
      aspect-ratio: 16 / 9;
    }

    .blog-landing__featured-content {
      padding: 1.75rem;
    }

    .blog-landing__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 560px) {
    .blog-landing__header {
      padding: 2.5rem 0 2rem;
    }

    .blog-landing__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.blog_landing.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "info": "t:sections.blog_landing.heading_info"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading"
    },
    {
      "type": "checkbox",
      "id": "show_featured",
      "label": "t:sections.blog_landing.show_featured",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_read_time",
      "label": "t:sections.blog_landing.show_read_time",
      "default": true
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "t:labels.columns_desktop",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" }
      ],
      "default": "3"
    },
    {
      "type": "range",
      "id": "articles_per_page",
      "label": "t:sections.blog_landing.articles_per_page",
      "min": 3,
      "max": 12,
      "step": 3,
      "default": 9
    }
  ]
}
{% endschema %}
