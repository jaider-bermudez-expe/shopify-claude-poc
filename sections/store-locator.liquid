<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" crossorigin="">

<section class="store-locator" id="section-{{ section.id }}">

  <div class="store-locator__header full-width">
    <h1 class="store-locator__heading">{{ section.settings.heading | escape }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="store-locator__subheading">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}
  </div>

  <div class="store-locator__controls full-width">
    <div class="store-locator__controls-inner">
      <div class="store-locator__search-wrap">
        <svg class="store-locator__search-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        <input
          type="search"
          class="store-locator__search-input"
          id="sl-search-{{ section.id }}"
          placeholder="{{ 'sections.store_locator.search_placeholder' | t }}"
          autocomplete="off"
          aria-label="{{ 'sections.store_locator.search_placeholder' | t }}"
        >
      </div>
      <button class="store-locator__near-me" id="sl-near-me-{{ section.id }}" type="button">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M1 12h4M19 12h4"/>
        </svg>
        <span>{{ 'sections.store_locator.near_me' | t }}</span>
      </button>
    </div>
    <div class="store-locator__chips-wrap">
      <div class="store-locator__chips" id="sl-chips-{{ section.id }}" role="group" aria-label="{{ 'sections.store_locator.filter_by_city' | t }}"></div>
    </div>
  </div>

  <div class="store-locator__body full-width">
    <div class="store-locator__map-panel">
      <div id="sl-map-{{ section.id }}" class="store-locator__map"></div>
    </div>
    <div class="store-locator__list-panel">
      <p class="store-locator__count" id="sl-count-{{ section.id }}" aria-live="polite"></p>
      <ul class="store-locator__list" id="sl-list-{{ section.id }}" role="list"></ul>
    </div>
  </div>

</section>

<script type="application/json" id="sl-data-{{ section.id }}">
  [
    {%- for block in section.blocks -%}
    {
      "id": {{ forloop.index0 }},
      "name": {{ block.settings.name | json }},
      "address": {{ block.settings.address | json }},
      "city": {{ block.settings.city | json }},
      "state": {{ block.settings.state | json }},
      "zip": {{ block.settings.zip | json }},
      "phone": {{ block.settings.phone | json }},
      "hours": {{ block.settings.hours | json }},
      "lat": {{ block.settings.lat | plus: 0 }},
      "lng": {{ block.settings.lng | plus: 0 }},
      "inventory_status": {{ block.settings.inventory_status | json }},
      "inventory_text": {{ block.settings.inventory_text | json }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
</script>

{% stylesheet %}
  .store-locator {
    padding-bottom: 4rem;
  }

  .store-locator__header {
    padding: 3rem var(--page-margin) 1.75rem;
    text-align: center;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .store-locator__heading {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    margin: 0 0 0.5rem;
  }

  .store-locator__subheading {
    color: var(--color-foreground);
    opacity: 0.6;
    margin: 0;
    font-size: 1.0625rem;
  }

  /* Controls */
  .store-locator__controls {
    padding: 0 var(--page-margin) 1.25rem;
  }

  .store-locator__controls-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    max-width: var(--page-width);
    margin: 0 auto 1rem;
    flex-wrap: wrap;
  }

  .store-locator__search-wrap {
    position: relative;
    flex: 1;
    min-width: 220px;
  }

  .store-locator__search-icon {
    position: absolute;
    left: 0.875rem;
    top: 50%;
    transform: translateY(-50%);
    opacity: 0.4;
    pointer-events: none;
  }

  .store-locator__search-input {
    width: 100%;
    height: 2.75rem;
    padding: 0 1rem 0 2.625rem;
    border: 1px solid rgba(0, 0, 0, 0.15);
    border-radius: var(--style-border-radius-inputs, 0.375rem);
    font-size: 0.9375rem;
    background: var(--color-background);
    color: var(--color-foreground);
    transition: border-color 0.15s;
  }

  .store-locator__search-input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.06);
  }

  .store-locator__near-me {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    height: 2.75rem;
    padding: 0 1.25rem;
    background: var(--color-foreground);
    color: var(--color-background);
    border: none;
    border-radius: var(--style-border-radius-inputs, 0.375rem);
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity 0.15s;
    flex-shrink: 0;
  }

  .store-locator__near-me:hover { opacity: 0.82; }
  .store-locator__near-me:disabled { opacity: 0.45; cursor: wait; }
  .store-locator__near-me.is-located { background: #166534; }

  .store-locator__chips-wrap {
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .store-locator__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .sl-chip {
    display: inline-flex;
    align-items: center;
    height: 2rem;
    padding: 0 0.875rem;
    border-radius: 99px;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background: none;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    color: var(--color-foreground);
    transition: background 0.15s, border-color 0.15s, color 0.15s;
  }

  .sl-chip:hover {
    background: rgba(0, 0, 0, 0.05);
  }

  .sl-chip.is-active {
    background: var(--color-foreground);
    color: var(--color-background);
    border-color: var(--color-foreground);
  }

  /* Body */
  .store-locator__body {
    display: grid;
    grid-template-columns: 1fr 400px;
    height: 620px;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .store-locator__map-panel {
    position: relative;
    overflow: hidden;
    isolation: isolate;
  }

  .store-locator__map {
    width: 100%;
    height: 100%;
  }

  /* List panel */
  .store-locator__list-panel {
    display: flex;
    flex-direction: column;
    border-left: 1px solid rgba(0, 0, 0, 0.08);
    background: var(--color-background);
    overflow: hidden;
  }

  .store-locator__count {
    padding: 0.75rem 1.25rem;
    font-size: 0.8125rem;
    opacity: 0.5;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    flex-shrink: 0;
    margin: 0;
  }

  .store-locator__list {
    list-style: none;
    padding: 0;
    margin: 0;
    overflow-y: auto;
    flex: 1;
  }

  /* Store card */
  .sl-card {
    padding: 1.125rem 1.25rem;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    cursor: pointer;
    transition: background 0.12s;
  }

  .sl-card:hover { background: rgba(0, 0, 0, 0.025); }
  .sl-card.is-active { background: rgba(0, 0, 0, 0.04); }

  .sl-card__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.625rem;
    margin-bottom: 0.3rem;
  }

  .sl-card__name {
    font-weight: 600;
    font-size: 0.9375rem;
    margin: 0;
    line-height: 1.3;
  }

  .sl-badge {
    font-size: 0.6875rem;
    font-weight: 600;
    padding: 0.2rem 0.5rem;
    border-radius: 99px;
    white-space: nowrap;
    flex-shrink: 0;
    line-height: 1.6;
  }

  .sl-badge--in_stock    { background: #dcfce7; color: #166534; }
  .sl-badge--limited     { background: #fef9c3; color: #854d0e; }
  .sl-badge--out_of_stock{ background: #fee2e2; color: #991b1b; }

  .sl-card__address {
    font-size: 0.8125rem;
    opacity: 0.6;
    margin: 0 0 0.3rem;
  }

  .sl-card__inventory {
    font-size: 0.75rem;
    opacity: 0.55;
    margin: 0 0 0.625rem;
  }

  .sl-card__meta {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 0.75rem;
  }

  .sl-card__meta-row {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .sl-card__meta-row svg { flex-shrink: 0; opacity: 0.7; }

  .sl-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .sl-card__directions {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-foreground);
    text-decoration: underline;
    text-underline-offset: 2px;
    text-decoration-color: rgba(0, 0, 0, 0.3);
  }

  .sl-card__directions:hover { text-decoration-color: var(--color-foreground); }

  .sl-card__distance {
    font-size: 0.75rem;
    font-weight: 500;
    opacity: 0.45;
  }

  .sl-empty {
    padding: 3rem 1.5rem;
    text-align: center;
    opacity: 0.45;
    font-size: 0.9375rem;
  }

  /* Leaflet overrides */
  .leaflet-container { font-family: inherit; }

  /* Responsive */
  @media (max-width: 860px) {
    .store-locator__body {
      grid-template-columns: 1fr;
      grid-template-rows: 320px auto;
      height: auto;
    }

    .store-locator__list-panel {
      border-left: none;
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      max-height: 420px;
    }
  }
{% endstylesheet %}

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" crossorigin=""></script>
<script>
(function () {
  var sid    = '{{ section.id }}';
  var stores = JSON.parse(document.getElementById('sl-data-' + sid).textContent);

  var mapEl    = document.getElementById('sl-map-' + sid);
  var listEl   = document.getElementById('sl-list-' + sid);
  var countEl  = document.getElementById('sl-count-' + sid);
  var chipsEl  = document.getElementById('sl-chips-' + sid);
  var searchEl = document.getElementById('sl-search-' + sid);
  var nearBtn  = document.getElementById('sl-near-me-' + sid);

  var map         = null;
  var markers     = {};
  var activeId    = null;
  var activeChip  = null;
  var userCoords  = null;
  var searchTimer = null;

  var BADGE_LABEL = {
    in_stock:     '{{ 'sections.store_locator.in_stock' | t }}',
    limited:      '{{ 'sections.store_locator.limited' | t }}',
    out_of_stock: '{{ 'sections.store_locator.out_of_stock' | t }}'
  };

  /* ── Map ─────────────────────────────────────── */
  map = L.map(mapEl, { center: [39.5, -98.35], zoom: 4, zoomControl: true });

  L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
    attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    maxZoom: 19
  }).addTo(map);

  function makeIcon(active) {
    return L.divIcon({
      html: '<div class="sl-pin' + (active ? ' sl-pin--active' : '') + '"></div>',
      className: '',
      iconSize: [22, 30],
      iconAnchor: [11, 30],
      popupAnchor: [0, -30]
    });
  }

  /* ── Distance ────────────────────────────────── */
  function haversineKm(lat1, lng1, lat2, lng2) {
    var R = 6371;
    var dLat = (lat2 - lat1) * Math.PI / 180;
    var dLng = (lng2 - lng1) * Math.PI / 180;
    var a = Math.sin(dLat / 2) * Math.sin(dLat / 2) +
            Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
            Math.sin(dLng / 2) * Math.sin(dLng / 2);
    return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
  }

  /* ── Filter chips ────────────────────────────── */
  var cityKeys = [];
  stores.forEach(function (s) {
    var key = s.city + ', ' + s.state;
    if (cityKeys.indexOf(key) === -1) cityKeys.push(key);
  });

  function addChip(label, key) {
    var btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'sl-chip' + (key === null ? ' is-active' : '');
    btn.textContent = label;
    btn.addEventListener('click', function () {
      activeChip = key;
      chipsEl.querySelectorAll('.sl-chip').forEach(function (c) {
        c.classList.toggle('is-active', c === btn);
      });
      render();
    });
    if (key === null) activeChip = null;
    chipsEl.appendChild(btn);
    return btn;
  }

  addChip('{{ 'sections.store_locator.all_stores' | t }}', null);
  cityKeys.forEach(function (k) { addChip(k, k); });

  /* ── Search ──────────────────────────────────── */
  searchEl.addEventListener('input', function () {
    clearTimeout(searchTimer);
    searchTimer = setTimeout(render, 180);
  });

  /* ── Near me ─────────────────────────────────── */
  if (!navigator.geolocation) nearBtn.style.display = 'none';

  nearBtn.addEventListener('click', function () {
    nearBtn.disabled = true;
    nearBtn.querySelector('span').textContent = '{{ 'sections.store_locator.locating' | t }}';
    navigator.geolocation.getCurrentPosition(
      function (pos) {
        userCoords = { lat: pos.coords.latitude, lng: pos.coords.longitude };
        nearBtn.disabled = false;
        nearBtn.classList.add('is-located');
        nearBtn.querySelector('span').textContent = '{{ 'sections.store_locator.near_me_active' | t }}';
        activeChip = null;
        chipsEl.querySelectorAll('.sl-chip').forEach(function (c, i) {
          c.classList.toggle('is-active', i === 0);
        });
        render();
      },
      function () {
        nearBtn.disabled = false;
        nearBtn.querySelector('span').textContent = '{{ 'sections.store_locator.near_me' | t }}';
      }
    );
  });

  /* ── Render ──────────────────────────────────── */
  function render() {
    var query = searchEl.value.trim().toLowerCase();

    var visible = stores.filter(function (s) {
      var cityKey = s.city + ', ' + s.state;
      if (activeChip && cityKey !== activeChip) return false;
      if (query) {
        var hay = [s.name, s.address, s.city, s.state, s.zip, s.phone].join(' ').toLowerCase();
        if (hay.indexOf(query) === -1) return false;
      }
      return true;
    });

    if (userCoords) {
      visible.sort(function (a, b) {
        return haversineKm(userCoords.lat, userCoords.lng, a.lat, a.lng) -
               haversineKm(userCoords.lat, userCoords.lng, b.lat, b.lng);
      });
    }

    countEl.textContent = visible.length + ' ' + (visible.length === 1
      ? '{{ 'sections.store_locator.store_singular' | t }}'
      : '{{ 'sections.store_locator.store_plural' | t }}');

    renderList(visible);
    renderMarkers(visible);

    if (visible.length > 0) {
      var bounds = L.latLngBounds(visible.map(function (s) { return [s.lat, s.lng]; }));
      map.fitBounds(bounds, { padding: [48, 48], maxZoom: 13 });
    }
  }

  /* ── List ────────────────────────────────────── */
  function renderList(visible) {
    listEl.innerHTML = '';

    if (visible.length === 0) {
      var empty = document.createElement('li');
      empty.className = 'sl-empty';
      empty.textContent = '{{ 'sections.store_locator.no_results' | t }}';
      listEl.appendChild(empty);
      return;
    }

    visible.forEach(function (store) {
      var dist = userCoords
        ? (haversineKm(userCoords.lat, userCoords.lng, store.lat, store.lng) * 0.6214).toFixed(1) + ' mi'
        : null;

      var li = document.createElement('li');
      li.className = 'sl-card' + (store.id === activeId ? ' is-active' : '');
      li.dataset.id = store.id;
      li.innerHTML = buildCard(store, dist);
      li.addEventListener('click', function (e) {
        if (e.target.tagName === 'A') return;
        selectStore(store.id);
      });
      listEl.appendChild(li);
    });
  }

  function buildCard(s, dist) {
    var badge = BADGE_LABEL[s.inventory_status] || s.inventory_status;
    var mapsUrl = 'https://www.google.com/maps/search/?api=1&query=' +
      encodeURIComponent(s.address + ', ' + s.city + ' ' + s.state + ' ' + s.zip);

    return '<div class="sl-card__top">' +
      '<h3 class="sl-card__name">' + esc(s.name) + '</h3>' +
      '<span class="sl-badge sl-badge--' + esc(s.inventory_status) + '">' + esc(badge) + '</span>' +
      '</div>' +
      '<p class="sl-card__address">' + esc(s.address) + ', ' + esc(s.city) + ', ' + esc(s.state) + ' ' + esc(s.zip) + '</p>' +
      '<p class="sl-card__inventory">' + esc(s.inventory_text) + '</p>' +
      '<div class="sl-card__meta">' +
        '<div class="sl-card__meta-row">' +
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>' +
          esc(s.phone) +
        '</div>' +
        '<div class="sl-card__meta-row">' +
          '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>' +
          esc(s.hours) +
        '</div>' +
      '</div>' +
      '<div class="sl-card__footer">' +
        '<a href="' + mapsUrl + '" class="sl-card__directions" target="_blank" rel="noopener">{{ 'sections.store_locator.get_directions' | t }}</a>' +
        (dist ? '<span class="sl-card__distance">' + esc(dist) + '</span>' : '') +
      '</div>';
  }

  function esc(str) {
    return String(str)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  /* ── Markers ─────────────────────────────────── */
  function renderMarkers(visible) {
    Object.values(markers).forEach(function (m) { map.removeLayer(m); });
    markers = {};

    visible.forEach(function (store) {
      var m = L.marker([store.lat, store.lng], {
        icon: makeIcon(store.id === activeId),
        title: store.name
      }).addTo(map);
      m.on('click', function () { selectStore(store.id); });
      markers[store.id] = m;
    });
  }

  /* ── Select ──────────────────────────────────── */
  function selectStore(id) {
    activeId = id;

    listEl.querySelectorAll('.sl-card').forEach(function (c) {
      var active = parseInt(c.dataset.id) === id;
      c.classList.toggle('is-active', active);
      if (active) c.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });

    Object.keys(markers).forEach(function (k) {
      markers[k].setIcon(makeIcon(parseInt(k) === id));
    });

    var store = stores.find(function (s) { return s.id === id; });
    if (store) map.flyTo([store.lat, store.lng], 14, { duration: 0.75 });
  }

  /* ── Marker CSS (injected once) ──────────────── */
  var pinStyle = document.createElement('style');
  pinStyle.textContent =
    '.sl-pin{width:22px;height:30px;background:var(--color-foreground);' +
    'border-radius:50% 50% 50% 0;transform:rotate(-45deg);' +
    'border:2px solid #fff;box-shadow:0 2px 6px rgba(0,0,0,.35);transition:background .15s,transform .15s}' +
    '.sl-pin--active{background:var(--color-accent);transform:rotate(-45deg) scale(1.25)}';
  document.head.appendChild(pinStyle);

  /* ── Init ────────────────────────────────────── */
  render();
})();
</script>

{% schema %}
{
  "name": "t:sections.store_locator.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Find a store"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Visit us in person — find your nearest location below"
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "t:sections.store_locator.block_name",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "t:labels.heading",
          "default": "Store name"
        },
        {
          "type": "text",
          "id": "address",
          "label": "t:sections.store_locator.address"
        },
        {
          "type": "text",
          "id": "city",
          "label": "t:sections.store_locator.city"
        },
        {
          "type": "text",
          "id": "state",
          "label": "t:sections.store_locator.state"
        },
        {
          "type": "text",
          "id": "zip",
          "label": "t:sections.store_locator.zip"
        },
        {
          "type": "text",
          "id": "phone",
          "label": "t:sections.store_locator.phone"
        },
        {
          "type": "text",
          "id": "hours",
          "label": "t:sections.store_locator.hours",
          "default": "Mon–Sat 10am–8pm, Sun 11am–6pm"
        },
        {
          "type": "text",
          "id": "lat",
          "label": "t:sections.store_locator.latitude",
          "info": "t:sections.store_locator.coords_info"
        },
        {
          "type": "text",
          "id": "lng",
          "label": "t:sections.store_locator.longitude"
        },
        {
          "type": "select",
