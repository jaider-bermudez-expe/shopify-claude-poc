<footer class="footer full-width">
  <div class="footer__inner">
    <div class="footer__brand">
      {%- assign shop_name_escaped = shop.name | escape -%}
      <a href="{{ routes.root_url }}" class="footer__logo" aria-label="{{ shop_name_escaped }}">
        {%- if section.settings.logo -%}
          {{
            section.settings.logo
            | image_url: width: 200
            | image_tag:
              class: 'footer__logo-image',
              alt: shop_name_escaped,
              loading: 'lazy',
              width: section.settings.logo.width,
              height: section.settings.logo.height
          }}
        {%- else -%}
          <span class="footer__logo--text">{{ shop.name | escape }}</span>
        {%- endif -%}
      </a>

      {%- if section.settings.tagline != blank -%}
        <p class="footer__tagline">{{ section.settings.tagline | escape }}</p>
      {%- endif -%}

      {%- assign has_social = false -%}
      {%- if section.settings.instagram_url != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.facebook_url != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.pinterest_url != blank -%}{%- assign has_social = true -%}{%- endif -%}
      {%- if section.settings.tiktok_url != blank -%}{%- assign has_social = true -%}{%- endif -%}

      {%- if has_social -%}
        <div class="footer__social" aria-label="{{ 'sections.footer.social_links' | t }}">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="footer__social-link" aria-label="{{ 'sections.footer.instagram' | t }}" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="footer__social-link" aria-label="{{ 'sections.footer.facebook' | t }}" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.pinterest_url != blank -%}
            <a href="{{ section.settings.pinterest_url }}" class="footer__social-link" aria-label="{{ 'sections.footer.pinterest' | t }}" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"/></svg>
            </a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" class="footer__social-link" aria-label="{{ 'sections.footer.tiktok' | t }}" target="_blank" rel="noopener noreferrer">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.31 6.31 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.menu_1 != blank -%}
      <div class="footer__column">
        {%- if section.settings.menu_1_heading != blank -%}
          <h3 class="footer__column-heading">{{ section.settings.menu_1_heading | escape }}</h3>
        {%- endif -%}
        <ul class="footer__link-list" role="list">
          {%- for link in section.settings.menu_1.links -%}
            <li><a href="{{ link.url }}" class="footer__link">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- else -%}
      <div class="footer__column">
        <h3 class="footer__column-heading">{{ 'sections.footer.shop_heading' | t }}</h3>
        <ul class="footer__link-list" role="list">
          <li><a href="/collections/home-garden" class="footer__link">{{ 'sections.footer.sample_home_garden' | t }}</a></li>
          <li><a href="/collections/jewelry" class="footer__link">{{ 'sections.footer.sample_jewelry' | t }}</a></li>
          <li><a href="/collections/clothing" class="footer__link">{{ 'sections.footer.sample_clothing' | t }}</a></li>
          <li><a href="/collections/all?sort_by=created-descending" class="footer__link">{{ 'sections.footer.sample_new_arrivals' | t }}</a></li>
          <li><a href="/collections/sale" class="footer__link">{{ 'sections.footer.sample_sale' | t }}</a></li>
        </ul>
      </div>
    {%- endif -%}

    {%- if section.settings.menu_2 != blank -%}
      <div class="footer__column">
        {%- if section.settings.menu_2_heading != blank -%}
          <h3 class="footer__column-heading">{{ section.settings.menu_2_heading | escape }}</h3>
        {%- endif -%}
        <ul class="footer__link-list" role="list">
          {%- for link in section.settings.menu_2.links -%}
            <li><a href="{{ link.url }}" class="footer__link">{{ link.title | escape }}</a></li>
          {%- endfor -%}
        </ul>
      </div>
    {%- else -%}
      <div class="footer__column">
        <h3 class="footer__column-heading">{{ 'sections.footer.help_heading' | t }}</h3>
        <ul class="footer__link-list" role="list">
          <li><a href="/blogs/news" class="footer__link">{{ 'sections.footer.sample_blog' | t }}</a></li>
          <li><a href="/pages/reviews" class="footer__link">{{ 'sections.footer.sample_reviews' | t }}</a></li>
          <li><a href="/pages/faq" class="footer__link">{{ 'sections.footer.sample_faq' | t }}</a></li>
          <li><a href="/pages/shipping" class="footer__link">{{ 'sections.footer.sample_shipping' | t }}</a></li>
          <li><a href="/pages/returns" class="footer__link">{{ 'sections.footer.sample_returns' | t }}</a></li>
          <li><a href="/pages/about" class="footer__link">{{ 'sections.footer.sample_about' | t }}</a></li>
          <li><a href="/pages/contact" class="footer__link">{{ 'sections.footer.sample_contact' | t }}</a></li>
        </ul>
      </div>
    {%- endif -%}

    <div class="footer__column">
      <h3 class="footer__column-heading">{{ 'sections.footer.newsletter_heading' | t }}</h3>
      <p class="footer__newsletter-desc">{{ 'sections.footer.newsletter_text' | t }}</p>

      {%- form 'customer', class: 'footer__newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {%- if form.posted_successfully? -%}
          <p class="footer__newsletter-success">{{ 'sections.newsletter.success' | t }}</p>
        {%- else -%}
          <div class="footer__newsletter-field">
            <input
              type="email"
              name="contact[email]"
              placeholder="{{ 'sections.newsletter.email_placeholder' | t }}"
              class="footer__newsletter-input"
              required
              autocomplete="email"
              aria-label="{{ 'sections.newsletter.email_placeholder' | t }}"
            >
            <button type="submit" class="footer__newsletter-btn" aria-label="{{ 'sections.newsletter.submit' | t }}">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </button>
          </div>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>

  <div class="footer__bottom">
    <p class="footer__copyright">
      &copy; {{ 'now' | date: '%Y' }}
      <a href="{{ routes.root_url }}">{{ shop.name | escape }}</a>.
      {{ 'sections.footer.rights' | t }}
    </p>

    {%- if section.settings.show_payment_icons -%}
      <div class="footer__payment" aria-label="{{ 'sections.footer.payment_methods' | t }}">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'footer__payment-icon' }}
        {%- endfor -%}
      </div>
    {%- endif -%}

    <button class="footer__back-to-top" aria-label="{{ 'sections.footer.back_to_top' | t }}" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"></polyline></svg>
      <span>{{ 'sections.footer.back_to_top' | t }}</span>
    </button>
  </div>
</footer>

{% stylesheet %}
  .footer {
    margin-top: auto;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
    gap: 3rem;
    padding: 3.5rem var(--page-margin) 2.5rem;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__logo {
    text-decoration: none;
    color: var(--color-foreground);
    display: inline-flex;
    align-self: flex-start;
  }

  .footer__logo-image {
    max-height: 1.875rem;
    width: auto;
    height: auto;
  }

  .footer__logo--text {
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.025em;
  }

  .footer__tagline {
    font-size: 0.875rem;
    opacity: 0.55;
    line-height: 1.6;
    max-width: 26ch;
    margin: 0;
  }

  .footer__social {
    display: flex;
    gap: 0.625rem;
    align-items: center;
    margin-top: 0.25rem;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 50%;
    border: 1px solid rgba(0, 0, 0, 0.15);
    color: var(--color-foreground);
    text-decoration: none;
    transition: background-color var(--transition-base), border-color var(--transition-base), color var(--transition-base);
  }

  .footer__social-link:hover {
    background-color: var(--color-foreground);
    border-color: var(--color-foreground);
    color: var(--color-background);
  }

  .footer__column {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer__column-heading {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin: 0;
  }

  .footer__link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .footer__link {
    text-decoration: none;
    color: var(--color-foreground);
    font-size: 0.875rem;
    opacity: 0.65;
    transition: opacity var(--transition-base);
    display: inline-block;
  }

  .footer__link:hover {
    opacity: 1;
  }

  .footer__newsletter-desc {
    font-size: 0.875rem;
    opacity: 0.6;
    margin: 0;
    line-height: 1.55;
  }

  .footer__newsletter-field {
    display: flex;
    border: 1.5px solid rgba(0, 0, 0, 0.2);
    border-radius: var(--style-border-radius-inputs);
    overflow: hidden;
    transition: border-color var(--transition-base);
  }

  .footer__newsletter-field:focus-within {
    border-color: var(--color-foreground);
  }

  .footer__newsletter-input {
    flex: 1;
    padding: 0.625rem 0.875rem;
    border: none;
    background: transparent;
    font-size: 0.875rem;
    min-width: 0;
    color: var(--color-foreground);
  }

  .footer__newsletter-input::placeholder {
    opacity: 0.4;
  }

  .footer__newsletter-input:focus {
    outline: none;
  }

  .footer__newsletter-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 0.875rem;
    background: var(--color-foreground);
    color: var(--color-background);
    border: none;
    cursor: pointer;
    transition: opacity var(--transition-base);
    flex-shrink: 0;
  }

  .footer__newsletter-btn:hover {
    opacity: 0.75;
  }

  .footer__newsletter-success {
    font-size: 0.875rem;
    color: #2d7a3a;
    font-weight: 500;
    margin: 0;
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.25rem var(--page-margin);
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    max-width: var(--page-width);
    margin: 0 auto;
    flex-wrap: wrap;
    gap: 1rem;
    width: 100%;
  }

  .footer__copyright {
    font-size: 0.8rem;
    opacity: 0.45;
    margin: 0;
  }

  .footer__copyright a {
    color: inherit;
    text-decoration: none;
  }

  .footer__payment {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }

  .footer__payment-icon {
    height: 1.5rem;
    width: auto;
    opacity: 0.55;
  }

  .footer__back-to-top {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8rem;
    opacity: 0.5;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    padding: 0;
    transition: opacity var(--transition-base);
    order: 3;
  }

  .footer__back-to-top:hover {
    opacity: 1;
  }

  @media (max-width: 960px) {
    .footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }

    .footer__brand {
      grid-column: 1 / -1;
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer__brand > .footer__logo {
      flex: 1 0 100%;
    }

    .footer__tagline {
      max-width: none;
      flex: 1;
    }

    .footer__social {
      margin-top: 0;
    }
  }

  @media (max-width: 560px) {
    .footer__inner {
      grid-template-columns: 1fr;
    }

    .footer__brand {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer__brand > .footer__logo {
      flex: 0 0 auto;
    }

    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }

    .footer__back-to-top {
      order: 0;
      align-self: flex-end;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var btn = document.querySelector('.footer__back-to-top');
    if (!btn) return;
    btn.addEventListener('click', function () {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:labels.logo"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "t:labels.text",
      "default": "Quality crafted for modern living."
    },
    {
      "type": "header",
      "content": "t:labels.social_links"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:labels.instagram_url"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "t:labels.facebook_url"
    },
    {
      "type": "url",
      "id": "pinterest_url",
      "label": "t:labels.pinterest_url"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "t:labels.tiktok_url"
    },
    {
      "type": "header",
      "content": "t:labels.navigation"
    },
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "menu_1_heading",
      "label": "t:labels.heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "t:labels.menu"
    },
    {
      "type": "text",
      "id": "menu_2_heading",
      "label": "t:labels.heading",
      "default": "Help"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
