{%- if section.settings.text != blank -%}
  <div
    class="promo-banner full-width"
    style="
      --promo-bg: {{ section.settings.background_color }};
      --promo-color: {{ section.settings.text_color }};
    "
  >
    <p class="promo-banner__text">
      {%- if section.settings.url != blank -%}
        <a href="{{ section.settings.url }}" class="promo-banner__link">
          {{ section.settings.text | escape }}
          {%- if section.settings.link_text != blank -%}
            &nbsp;&mdash;&nbsp;<span class="promo-banner__cta">{{ section.settings.link_text | escape }}</span>
          {%- endif -%}
        </a>
      {%- else -%}
        {{ section.settings.text | escape }}
      {%- endif -%}
    </p>
  </div>
{%- endif -%}

{% stylesheet %}
  .promo-banner {
    background-color: var(--promo-bg);
    color: var(--promo-color);
    padding: 0.75rem var(--page-margin);
    text-align: center;
  }

  .promo-banner__text {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .promo-banner__link {
    color: inherit;
    text-decoration: none;
  }

  .promo-banner__link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .promo-banner__cta {
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.promo_banner",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.foreground",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "text",
      "label": "t:labels.text",
      "default": "Free shipping on orders over $75"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:labels.button_label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:labels.button_url"
    }
  ],
  "presets": [
    {
      "name": "t:general.promo_banner"
    }
  ]
}
{% endschema %}
