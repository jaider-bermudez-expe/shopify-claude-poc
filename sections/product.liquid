{%- assign current_variant = product.selected_or_first_available_variant -%}
{%- assign main_image_id = 'product-main-image-' | append: section.id -%}
{%- assign product_form_id = 'product-form-' | append: section.id -%}

<div class="product-page" id="product-page-{{ section.id }}" data-product-id="{{ product.id }}">
  <div class="product-gallery" id="product-gallery-{{ section.id }}">
    <div class="product-gallery__main">
      {%- if product.images.size > 0 -%}
        {%- assign main_image_alt = product.images[0].alt | escape -%}
        {{
          product.images[0]
          | image_url: width: 900
          | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            class: 'product-gallery__main-image',
            id: main_image_id,
            alt: main_image_alt
        }}
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'product-gallery__main-image' }}
      {%- endif -%}
    </div>

    {%- if product.images.size > 1 -%}
      <div class="product-gallery__thumbs">
        {%- for image in product.images -%}
          {%- assign thumb_alt = image.alt | escape -%}
          <button
            class="product-gallery__thumb{% if forloop.first %} product-gallery__thumb--active{% endif %}"
            type="button"
            aria-label="{{ 'sections.product.image' | t }} {{ forloop.index }}"
            data-image-url="{{ image | image_url: width: 900 }}"
            data-image-alt="{{ thumb_alt }}"
          >
            {{
              image
              | image_url: width: 160
              | image_tag:
                class: 'product-gallery__thumb-img',
                alt: thumb_alt,
                loading: 'lazy'
            }}
          </button>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product-info">
    {%- if section.settings.show_vendor and product.vendor != blank -%}
      <p class="product-info__vendor">{{ product.vendor | escape }}</p>
    {%- endif -%}

    <h1 class="product-info__title">{{ product.title | escape }}</h1>

    <div class="product-info__price" id="product-price-{{ section.id }}">
      {%- if current_variant.compare_at_price > current_variant.price -%}
        <s class="product-info__price-compare">{{ current_variant.compare_at_price | money }}</s>
        <span class="product-info__price-sale">{{ current_variant.price | money }}</span>
        {%- assign discount_pct = current_variant.compare_at_price | minus: current_variant.price | times: 100 | divided_by: current_variant.compare_at_price -%}
        <span class="product-info__badge-discount">-{{ discount_pct }}%</span>
      {%- else -%}
        <span class="product-info__price-regular">{{ current_variant.price | money }}</span>
      {%- endif -%}
    </div>

    {%- form 'product', product, id: product_form_id, class: 'product-form' -%}
      <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id-{{ section.id }}">

      {%- unless product.has_only_default_variant -%}
        {%- for option in product.options_with_values -%}
          <div class="product-form__option">
            <div class="product-form__option-header">
              <span class="product-form__option-name">{{ option.name | escape }}</span>
              <span class="product-form__option-selected" id="option-value-{{ forloop.index }}-{{ section.id }}">
                {{ current_variant.options[forloop.index0] | escape }}
              </span>
            </div>

            <div class="product-form__option-values" data-option-index="{{ forloop.index0 }}">
              {%- for value in option.values -%}
                {%- assign is_selected = false -%}
                {%- if current_variant.options[forloop.parentloop.index0] == value -%}
                  {%- assign is_selected = true -%}
                {%- endif -%}
                <button
                  type="button"
                  class="product-form__option-btn{% if is_selected %} is-selected{% endif %}"
                  data-option-index="{{ forloop.parentloop.index0 }}"
                  data-value="{{ value | escape }}"
                  aria-pressed="{{ is_selected }}"
                >
                  {{ value | escape }}
                </button>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}
      {%- endunless -%}

      <div class="product-form__qty">
        <span class="product-form__qty-label">{{ 'sections.product.quantity' | t }}</span>
        <div class="product-form__qty-control">
          <button type="button" class="product-form__qty-btn" id="qty-minus-{{ section.id }}" aria-label="{{ 'sections.product.quantity_decrease' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
          <input
            type="number"
            id="quantity-{{ section.id }}"
            name="quantity"
            value="1"
            min="1"
            class="product-form__qty-input"
          >
          <button type="button" class="product-form__qty-btn" id="qty-plus-{{ section.id }}" aria-label="{{ 'sections.product.quantity_increase' | t }}">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
          </button>
        </div>
      </div>

      <div class="product-form__actions">
        <button
          type="submit"
          class="product-form__submit btn btn--primary"
          id="add-to-cart-{{ section.id }}"
          {%- unless current_variant.available -%}disabled{%- endunless -%}
        >
          {%- if current_variant.available -%}
            {{ 'sections.product.add_to_cart' | t }}
          {%- else -%}
            {{ 'sections.product.sold_out' | t }}
          {%- endif -%}
        </button>
        {{ form | payment_button }}
      </div>
    {%- endform -%}

    {%- if product.description != blank -%}
      <details class="product-accordion" open>
        <summary class="product-accordion__header">
          {{ 'sections.product.description' | t }}
          <svg class="product-accordion__chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
        </summary>
        <div class="product-accordion__body rte">
          {{ product.description }}
        </div>
      </details>
    {%- endif -%}
  </div>
</div>

{%- if recommendations.performed -%}
  {%- if recommendations.products_count > 0 -%}
    <section class="product-recommendations">
      <h2 class="product-recommendations__heading">{{ 'sections.product.recommendations_heading' | t }}</h2>
      <div class="product-recommendations__grid">
        {%- for rec_product in recommendations.products -%}
          {%- render 'product-card', product: rec_product, show_price: true, show_add_to_cart: true -%}
        {%- endfor -%}
      </div>
    </section>
  {%- endif -%}
{%- else -%}
  <div
    id="product-recommendations-{{ section.id }}"
    data-product-id="{{ product.id }}"
    data-section-id="{{ section.id }}"
    data-limit="{{ section.settings.recommendations_limit }}"
  ></div>
{%- endif -%}

{% render 'recently-viewed-tracker', product: product %}

{% stylesheet %}
  .product-page {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4.5rem;
    padding: 3rem 0 5rem;
    align-items: start;
  }

  /* Gallery */
  .product-gallery {
    position: sticky;
    top: 5.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .product-gallery__main {
    aspect-ratio: 1 / 1;
    border-radius: 1rem;
    overflow: hidden;
    background: #f5f5f0;
  }

  .product-gallery__main-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.2s ease;
    display: block;
  }

  .product-gallery__thumbs {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    scrollbar-width: none;
  }

  .product-gallery__thumbs::-webkit-scrollbar {
    display: none;
  }

  .product-gallery__thumb {
    flex-shrink: 0;
    width: 5rem;
    height: 5rem;
    border-radius: 0.5rem;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color var(--transition-base);
    background: none;
    padding: 0;
  }

  .product-gallery__thumb--active {
    border-color: var(--color-accent);
  }

  .product-gallery__thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Product info */
  .product-info {
    display: flex;
    flex-direction: column;
    gap: 1.375rem;
  }

  .product-info__vendor {
    font-size: 0.75rem;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0;
  }

  .product-info__title {
    font-size: clamp(1.5rem, 2.5vw, 2.125rem);
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .product-info__price {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    font-size: 1.375rem;
  }

  .product-info__price-compare {
    color: #bbb;
    font-size: 1.125rem;
    text-decoration: line-through;
  }

  .product-info__price-sale {
    color: #c00;
    font-weight: 700;
  }

  .product-info__badge-discount {
    background: #c00;
    color: #fff;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.03em;
  }

  /* Form */
  .product-form {
    display: flex;
    flex-direction: column;
    gap: 1.375rem;
    padding-top: 1.375rem;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
  }

  .product-form__option {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }

  .product-form__option-header {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    font-size: 0.875rem;
  }

  .product-form__option-name {
    font-weight: 700;
  }

  .product-form__option-selected {
    opacity: 0.55;
    font-weight: 400;
  }

  .product-form__option-values {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .product-form__option-btn {
    padding: 0.5rem 1rem;
    border: 1.5px solid rgba(0, 0, 0, 0.2);
    background: transparent;
    border-radius: var(--style-border-radius-inputs);
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color var(--transition-base), background-color var(--transition-base), color var(--transition-base);
    color: var(--color-foreground);
  }

  .product-form__option-btn:hover {
    border-color: var(--color-accent);
  }

  .product-form__option-btn.is-selected {
    border-color: var(--color-accent);
    background: var(--color-accent);
    color: var(--color-accent-foreground);
    font-weight: 600;
  }

  .product-form__qty {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .product-form__qty-label {
    font-size: 0.875rem;
    font-weight: 700;
  }

  .product-form__qty-control {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(0, 0, 0, 0.2);
    border-radius: var(--style-border-radius-inputs);
    overflow: hidden;
    width: fit-content;
  }

  .product-form__qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    background: transparent;
    border: none;
    cursor: pointer;
    color: var(--color-foreground);
    transition: background-color var(--transition-base);
  }

  .product-form__qty-btn:hover {
    background-color: rgba(0, 0, 0, 0.05);
  }

  .product-form__qty-input {
    width: 3.25rem;
    text-align: center;
    border: none;
    border-left: 1px solid rgba(0, 0, 0, 0.1);
    border-right: 1px solid rgba(0, 0, 0, 0.1);
    font-size: 0.9375rem;
    padding: 0;
    height: 2.75rem;
    background: transparent;
    color: var(--color-foreground);
    -moz-appearance: textfield;
  }

  .product-form__qty-input::-webkit-inner-spin-button,
  .product-form__qty-input::-webkit-outer-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .product-form__qty-input:focus {
    outline: none;
  }

  .product-form__actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .product-form__submit {
    width: 100%;
    font-size: 1rem;
    padding: 1.0625rem;
    letter-spacing: 0.05em;
  }

  /* Accordion */
  .product-accordion {
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }

  .product-accordion__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
    cursor: pointer;
    font-size: 0.9375rem;
    font-weight: 600;
    list-style: none;
  }

  .product-accordion__header::-webkit-details-marker {
    display: none;
  }

  .product-accordion__chevron {
    transition: transform var(--transition-base);
    flex-shrink: 0;
  }

  .product-accordion[open] .product-accordion__chevron {
    transform: rotate(180deg);
  }

  .product-accordion__body {
    padding-bottom: 1.375rem;
    font-size: 0.9375rem;
    line-height: 1.75;
    opacity: 0.72;
  }

  .rte a { color: var(--color-accent); }
  .rte p + p { margin-top: 0.75rem; }

  @media (max-width: 900px) {
    .product-page {
      grid-template-columns: 1fr;
      gap: 2rem;
      padding: 2rem 0 3rem;
    }

    .product-gallery {
      position: static;
    }
  }

  /* Recommendations */
  .product-recommendations {
    padding: 4rem 0 2rem;
    border-top: 1px solid rgba(0, 0, 0, 0.07);
    margin-top: 1rem;
  }

  .product-recommendations__heading {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 0 0 1.75rem;
  }

  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 900px) {
    .product-recommendations__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .product-recommendations__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.875rem;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var sectionId = '{{ section.id }}';
    var gallery = document.getElementById('product-gallery-' + sectionId);
    var qtyInput = document.getElementById('quantity-' + sectionId);
    var qtyMinus = document.getElementById('qty-minus-' + sectionId);
    var qtyPlus = document.getElementById('qty-plus-' + sectionId);

    /* Thumbnail switching */
    if (gallery) {
      var mainImg = gallery.querySelector('.product-gallery__main-image');
      gallery.querySelectorAll('.product-gallery__thumb').forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          if (mainImg) {
            mainImg.src = thumb.dataset.imageUrl;
            mainImg.alt = thumb.dataset.imageAlt || '';
          }
          gallery.querySelectorAll('.product-gallery__thumb').forEach(function (t) {
            t.classList.remove('product-gallery__thumb--active');
          });
          thumb.classList.add('product-gallery__thumb--active');
        });
      });
    }

    /* Quantity controls */
    if (qtyMinus && qtyPlus && qtyInput) {
      qtyMinus.addEventListener('click', function () {
        var val = parseInt(qtyInput.value, 10);
        if (val > 1) { qtyInput.value = String(val - 1); }
      });
      qtyPlus.addEventListener('click', function () {
        var val = parseInt(qtyInput.value, 10);
        qtyInput.value = String(val + 1);
      });
    }

    /* Variant option buttons — update selected label and hidden input */
    var productPage = document.getElementById('product-page-' + sectionId);
    if (productPage) {
      productPage.querySelectorAll('.product-form__option-values').forEach(function (group) {
        group.querySelectorAll('.product-form__option-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            group.querySelectorAll('.product-form__option-btn').forEach(function (b) {
              b.classList.remove('is-selected');
              b.setAttribute('aria-pressed', 'false');
            });
            btn.classList.add('is-selected');
            btn.setAttribute('aria-pressed', 'true');

            var optionIndex = parseInt(btn.dataset.optionIndex, 10);
            var labelEl = document.getElementById('option-value-' + (optionIndex + 1) + '-' + sectionId);
            if (labelEl) { labelEl.textContent = btn.dataset.value; }
          });
        });
      });
    }

    /* Recommendations — async load via Shopify section rendering API */
    var recsPlaceholder = document.getElementById('product-recommendations-' + sectionId);
    if (recsPlaceholder) {
      var productId = recsPlaceholder.dataset.productId;
      var limit = recsPlaceholder.dataset.limit || '4';
      var url = '/recommendations/products?section_id=' + sectionId + '&product_id=' + productId + '&limit=' + limit;
      fetch(url)
        .then(function (res) { return res.text(); })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');
          var recs = doc.querySelector('.product-recommendations');
          if (recs) { recsPlaceholder.replaceWith(recs); }
        })
        .catch(function () {});
    }
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": true
    },
    {
      "type": "range",
      "id": "recommendations_limit",
      "label": "t:labels.recommendations_limit",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
