{%- assign collection = section.settings.collection | default: collections.all -%}
{%- assign products_to_show = section.settings.products_to_show -%}

<div
  class="product-shelf"
  id="product-shelf-{{ section.id }}"
  style="--columns-mobile: {{ section.settings.columns_mobile }};"
>
  {%- if section.settings.heading != blank -%}
    <h2 class="product-shelf__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}

  <div class="product-shelf__container">
    <button
      class="product-shelf__nav product-shelf__nav--prev"
      aria-label="{{ 'sections.product_shelf.previous' | t }}"
      type="button"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="15 18 9 12 15 6"></polyline>
      </svg>
    </button>

    <div class="product-shelf__track" id="product-shelf-track-{{ section.id }}">
      {%- if collection and collection.products_count > 0 -%}
        {%- for product in collection.products limit: products_to_show -%}
          <div class="product-shelf__item">
            <a href="{{ product.url }}" class="product-shelf__link">
              <div class="product-shelf__image-wrapper">
                {%- if product.featured_image -%}
                  {{
                    product.featured_image
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      class: 'product-shelf__image',
                      alt: product.featured_image.alt | escape
                  }}
                {%- else -%}
                  {%- assign placeholder_index = forloop.index0 | modulo: 6 | plus: 1 -%}
                  {%- capture placeholder_svg -%}product-{{ placeholder_index }}{%- endcapture -%}
                  {{ placeholder_svg | placeholder_svg_tag: 'product-shelf__image product-shelf__image--placeholder' }}
                {%- endif -%}
              </div>

              <div class="product-shelf__info">
                {%- if section.settings.show_vendor -%}
                  <p class="product-shelf__vendor">{{ product.vendor }}</p>
                {%- endif -%}

                <h3 class="product-shelf__title">{{ product.title | escape }}</h3>

                {%- if section.settings.show_price -%}
                  <p class="product-shelf__price">
                    {%- if product.compare_at_price > product.price -%}
                      <s class="product-shelf__price--compare">{{ product.compare_at_price | money }}</s>
                      <span class="product-shelf__price--sale">{{ product.price | money }}</span>
                    {%- else -%}
                      <span>{{ product.price | money }}</span>
                    {%- endif -%}
                  </p>
                {%- endif -%}
              </div>
            </a>

            {%- if section.settings.show_add_to_cart -%}
              {%- if product.available -%}
                {%- form 'product', product, class: 'product-shelf__form' -%}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" class="product-shelf__add-btn">
                    {{ 'sections.product_shelf.add_to_cart' | t }}
                  </button>
                {%- endform -%}
              {%- else -%}
                <button type="button" class="product-shelf__add-btn product-shelf__add-btn--sold-out" disabled>
                  {{ 'sections.product_shelf.sold_out' | t }}
                </button>
              {%- endif -%}
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..products_to_show) -%}
          {%- assign placeholder_index = forloop.index0 | modulo: 6 | plus: 1 -%}
          {%- capture placeholder_svg -%}product-{{ placeholder_index }}{%- endcapture -%}
          <div class="product-shelf__item product-shelf__item--placeholder">
            <div class="product-shelf__link">
              <div class="product-shelf__image-wrapper">
                {{ placeholder_svg | placeholder_svg_tag: 'product-shelf__image' }}
              </div>
              <div class="product-shelf__info">
                <h3 class="product-shelf__title">{{ 'onboarding.product_title' | t }}</h3>
                {%- if section.settings.show_price -%}
                  <p class="product-shelf__price">
                    <span>{{ 'onboarding.product_price' | t }}</span>
                  </p>
                {%- endif -%}
              </div>
            </div>
            {%- if section.settings.show_add_to_cart -%}
              <button type="button" class="product-shelf__add-btn" disabled>
                {{ 'sections.product_shelf.add_to_cart' | t }}
              </button>
            {%- endif -%}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    <button
      class="product-shelf__nav product-shelf__nav--next"
      aria-label="{{ 'sections.product_shelf.next' | t }}"
      type="button"
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="9 18 15 12 9 6"></polyline>
      </svg>
    </button>
  </div>
</div>

{% stylesheet %}
  .product-shelf {
    padding: 2.5rem 0;
  }

  .product-shelf__heading {
    margin: 0 0 1.5rem;
    font-size: 1.75rem;
    font-weight: 700;
    text-align: center;
  }

  .product-shelf__container {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .product-shelf__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 1rem;
    flex: 1;
    padding-bottom: 0.25rem;
  }

  .product-shelf__track::-webkit-scrollbar {
    display: none;
  }

  .product-shelf__item {
    flex: 0 0 calc((100% - 4rem) / 5);
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
  }

  .product-shelf__item--placeholder {
    opacity: 0.6;
  }

  .product-shelf__link {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    flex: 1;
  }

  .product-shelf__image-wrapper {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 0.5rem;
    background-color: #f4f4f4;
  }

  .product-shelf__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s ease;
  }

  .product-shelf__link:hover .product-shelf__image:not(.product-shelf__image--placeholder) {
    transform: scale(1.04);
  }

  .product-shelf__info {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    flex: 1;
    padding: 0 0.1rem;
  }

  .product-shelf__vendor {
    font-size: 0.7rem;
    color: #888;
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .product-shelf__title {
    font-size: 0.9rem;
    font-weight: 500;
    margin: 0;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-shelf__price {
    margin: 0;
    font-size: 0.875rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    align-items: baseline;
  }

  .product-shelf__price--compare {
    color: #aaa;
    font-size: 0.8rem;
    text-decoration: line-through;
  }

  .product-shelf__price--sale {
    color: #c00;
    font-weight: 600;
  }

  .product-shelf__form {
    margin-top: 0.75rem;
  }

  .product-shelf__add-btn {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid currentColor;
    background: transparent;
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: 500;
    border-radius: 0.3rem;
    transition: background-color 0.2s ease, color 0.2s ease;
  }

  .product-shelf__add-btn:hover:not(:disabled) {
    background-color: #111;
    color: #fff;
    border-color: #111;
  }

  .product-shelf__add-btn--sold-out,
  .product-shelf__add-btn:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .product-shelf__nav {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid #ddd;
    background: #fff;
    border-radius: 50%;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .product-shelf__nav:hover:not(:disabled) {
    background-color: #111;
    color: #fff;
    border-color: #111;
  }

  .product-shelf__nav:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  @media (max-width: 749px) {
    .product-shelf__item {
      flex: 0 0 calc((100% - (var(--columns-mobile, 1) - 1) * 1rem) / var(--columns-mobile, 1));
    }

    .product-shelf__nav {
      display: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.getElementById('product-shelf-{{ section.id }}');
    if (!section) return;

    var track = section.querySelector('.product-shelf__track');
    var prevBtn = section.querySelector('.product-shelf__nav--prev');
    var nextBtn = section.querySelector('.product-shelf__nav--next');

    function updateNav() {
      prevBtn.disabled = track.scrollLeft <= 0;
      nextBtn.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 1;
    }

    prevBtn.addEventListener('click', function () {
      track.scrollBy({ left: -track.clientWidth, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', function () {
      track.scrollBy({ left: track.clientWidth, behavior: 'smooth' });
    });

    track.addEventListener('scroll', updateNav, { passive: true });
    updateNav();
  })();
{% endjavascript %}

{% schema %}
{
  "name": "t:general.product_shelf",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:general.collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "t:labels.products_to_show",
      "min": 20,
      "max": 50,
      "step": 1,
      "default": 20
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "t:labels.show_vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "t:labels.show_price",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_add_to_cart",
      "label": "t:labels.show_add_to_cart",
      "default": true
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "t:labels.columns_mobile",
      "default": "1",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.product_shelf"
    }
  ]
}
{% endschema %}
