<article class="article-page">

  {%- if article.image -%}
    <div class="article-page__hero">
      {%- assign hero_alt = article.image.alt | default: article.title | escape -%}
      {{
        article.image
        | image_url: width: 1600
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          class: 'article-page__hero-img',
          alt: hero_alt
      }}
    </div>
  {%- endif -%}

  <div class="article-page__container">

    <nav class="article-page__breadcrumb" aria-label="{{ 'sections.article.breadcrumb_label' | t }}">
      <a href="{{ routes.root_url }}">{{ 'sections.article.breadcrumb_home' | t }}</a>
      <span aria-hidden="true">/</span>
      <a href="{{ blog.url }}">{{ blog.title }}</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{ article.title }}</span>
    </nav>

    <header class="article-page__header">
      {%- if article.tags.size > 0 -%}
        <div class="article-page__tags">
          {%- for tag in article.tags -%}
            <a href="{{ blog.url }}/tagged/{{ tag | handleize }}" class="article-page__tag">{{ tag }}</a>
          {%- endfor -%}
        </div>
      {%- endif -%}

      <h1 class="article-page__title">{{ article.title }}</h1>

      <div class="article-page__meta">
        <div class="article-page__author">
          <span class="article-page__author-avatar" aria-hidden="true">{{ article.author | slice: 0 | upcase }}</span>
          <div class="article-page__author-info">
            <span class="article-page__author-name">{{ article.author }}</span>
            <time class="article-page__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
              {{ article.published_at | date: '%B %d, %Y' }}
            </time>
          </div>
        </div>
        {%- assign read_time = article.content | strip_html | split: ' ' | size | divided_by: 200 | at_least: 1 -%}
        <span class="article-page__read-time">{{ read_time }} {{ 'sections.blog_landing.min_read' | t }}</span>
      </div>
    </header>

    <div class="article-page__body rte">
      {{ article.content }}
    </div>

    <footer class="article-page__footer">
      <a href="{{ blog.url }}" class="article-page__back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        {{ 'sections.article.back_to_blog' | t: blog_title: blog.title }}
      </a>

      {%- if blog.next_article or blog.previous_article -%}
        <nav class="article-page__nav" aria-label="{{ 'sections.article.article_nav_label' | t }}">
          {%- if blog.previous_article -%}
            <a href="{{ blog.previous_article }}" class="article-page__nav-link article-page__nav-link--prev">
              <span class="article-page__nav-dir">{{ 'sections.article.previous' | t }}</span>
              <span class="article-page__nav-title">{{ blog.previous_article.title }}</span>
            </a>
          {%- endif -%}
          {%- if blog.next_article -%}
            <a href="{{ blog.next_article }}" class="article-page__nav-link article-page__nav-link--next">
              <span class="article-page__nav-dir">{{ 'sections.article.next' | t }}</span>
              <span class="article-page__nav-title">{{ blog.next_article.title }}</span>
            </a>
          {%- endif -%}
        </nav>
      {%- endif -%}
    </footer>

  </div>

</article>

{% stylesheet %}
  /* ── Hero ────────────────────────────────────── */
  .article-page__hero {
    width: 100%;
    max-height: 520px;
    overflow: hidden;
  }

  .article-page__hero-img {
    width: 100%;
    height: 520px;
    object-fit: cover;
    display: block;
  }

  /* ── Container ───────────────────────────────── */
  .article-page__container {
    max-width: 760px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }

  /* ── Breadcrumb ──────────────────────────────── */
  .article-page__breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #999;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .article-page__breadcrumb a {
    color: #999;
    text-decoration: none;
  }

  .article-page__breadcrumb a:hover {
    color: #333;
    text-decoration: underline;
  }

  .article-page__breadcrumb span[aria-current] {
    color: #555;
  }

  /* ── Header ──────────────────────────────────── */
  .article-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 1rem;
  }

  .article-page__tag {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent, #8b7355);
    background: rgba(139, 115, 85, 0.1);
    padding: 0.25rem 0.65rem;
    border-radius: 2rem;
    text-decoration: none;
  }

  .article-page__tag:hover {
    background: rgba(139, 115, 85, 0.18);
  }

  .article-page__title {
    font-size: clamp(1.75rem, 5vw, 2.75rem);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 1.5rem;
  }

  .article-page__meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid #e8e5e0;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
  }

  .article-page__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .article-page__author-avatar {
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--color-accent, #8b7355);
    color: #fff;
    font-size: 0.9rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .article-page__author-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .article-page__author-name {
    font-size: 0.9rem;
    font-weight: 600;
    color: #333;
  }

  .article-page__date {
    font-size: 0.8rem;
    color: #999;
  }

  .article-page__read-time {
    font-size: 0.8rem;
    color: #aaa;
    white-space: nowrap;
  }

  /* ── Body ────────────────────────────────────── */
  .article-page__body.rte {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #333;
  }

  .article-page__body.rte h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    line-height: 1.3;
  }

  .article-page__body.rte h3 {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 2rem 0 0.75rem;
  }

  .article-page__body.rte p {
    margin-bottom: 1.5rem;
  }

  .article-page__body.rte ul,
  .article-page__body.rte ol {
    margin: 0 0 1.5rem 1.5rem;
  }

  .article-page__body.rte li {
    margin-bottom: 0.5rem;
  }

  .article-page__body.rte img {
    max-width: 100%;
    height: auto;
    border-radius: 0.5rem;
    margin: 1.5rem 0;
  }

  .article-page__body.rte blockquote {
    border-left: 3px solid var(--color-accent, #8b7355);
    padding: 0.5rem 0 0.5rem 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #666;
    font-size: 1.1rem;
  }

  .article-page__body.rte a {
    color: var(--color-accent, #8b7355);
    text-decoration: underline;
  }

  /* ── Footer ──────────────────────────────────── */
  .article-page__footer {
    margin-top: 3.5rem;
    padding-top: 2rem;
    border-top: 1px solid #e8e5e0;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .article-page__back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent, #8b7355);
    text-decoration: none;
    transition: gap 0.15s ease;
  }

  .article-page__back-link:hover {
    gap: 0.6rem;
  }

  .article-page__nav {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .article-page__nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem 1.25rem;
    border: 1px solid #ede9e3;
    border-radius: 0.5rem;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .article-page__nav-link--next {
    text-align: right;
    margin-left: auto;
  }

  .article-page__nav-link:hover {
    border-color: var(--color-accent, #8b7355);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .article-page__nav-dir {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #aaa;
  }

  .article-page__nav-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: #333;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  @media (max-width: 560px) {
    .article-page__nav {
      grid-template-columns: 1fr;
    }

    .article-page__nav-link--next {
      text-align: left;
      margin-left: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.article",
  "settings": []
}
{% endschema %}
