<div class="featured-collections">
  {%- if section.settings.heading != blank -%}
    <h2 class="featured-collections__heading">{{ section.settings.heading | escape }}</h2>
  {%- endif -%}
  {%- if section.settings.subheading != blank -%}
    <p class="featured-collections__subheading">{{ section.settings.subheading | escape }}</p>
  {%- endif -%}

  <div class="featured-collections__grid">
    {%- for i in (1..3) -%}
      {%- assign col_key = 'collection_' | append: i -%}
      {%- assign col = section.settings[col_key] -%}
      {%- assign col_label_key = 'collection_' | append: i | append: '_label' -%}
      {%- assign col_label = section.settings[col_label_key] -%}

      {%- if col != blank -%}
        <a href="{{ col.url }}" class="collection-card">
          <div class="collection-card__media">
            {%- if col.image -%}
              {{
                col.image
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  class: 'collection-card__image',
                  alt: col.image.alt | default: col.title | escape
              }}
            {%- else -%}
              {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-card__image collection-card__image--placeholder' }}
            {%- endif -%}
          </div>
          <div class="collection-card__overlay"></div>
          <div class="collection-card__content">
            <h3 class="collection-card__title">
              {%- if col_label != blank -%}
                {{ col_label | escape }}
              {%- else -%}
                {{ col.title | escape }}
              {%- endif -%}
            </h3>
            <span class="collection-card__count">
              {{ col.products_count }} {{ 'sections.featured_collections.products' | t }}
            </span>
            <span class="collection-card__link">{{ 'sections.featured_collections.shop_now' | t }}</span>
          </div>
        </a>
      {%- else -%}
        <div class="collection-card collection-card--placeholder">
          <div class="collection-card__media">
            {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-card__image collection-card__image--placeholder' }}
          </div>
          <div class="collection-card__overlay"></div>
          <div class="collection-card__content">
            <h3 class="collection-card__title">{{ 'onboarding.collection_title' | t }}</h3>
            <span class="collection-card__link">{{ 'sections.featured_collections.shop_now' | t }}</span>
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .featured-collections {
    padding: 4rem 0;
  }

  .featured-collections__heading {
    text-align: center;
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .featured-collections__subheading {
    text-align: center;
    opacity: 0.6;
    font-size: 1rem;
    margin-bottom: 2rem;
  }

  .featured-collections__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .collection-card {
    position: relative;
    display: block;
    text-decoration: none;
    color: #fff;
    border-radius: 0.875rem;
    overflow: hidden;
    aspect-ratio: 3 / 4;
    background: #1a1a1a;
  }

  .collection-card__media {
    position: absolute;
    inset: 0;
  }

  .collection-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.55s ease;
    display: block;
  }

  .collection-card:hover .collection-card__image:not(.collection-card__image--placeholder) {
    transform: scale(1.05);
  }

  .collection-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.72) 0%, rgba(0, 0, 0, 0.12) 55%, transparent 100%);
    z-index: 1;
  }

  .collection-card__content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 2;
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .collection-card__title {
    font-size: 1.375rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .collection-card__count {
    font-size: 0.8rem;
    opacity: 0.7;
  }

  .collection-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-top: 0.625rem;
  }

  .collection-card__link::after {
    content: '→';
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .collection-card:hover .collection-card__link::after {
    transform: translateX(5px);
  }

  @media (max-width: 749px) {
    .featured-collections__grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .collection-card {
      aspect-ratio: 4 / 3;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.featured_collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Shop by category"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:labels.subheading",
      "default": "Explore our curated collections"
    },
    {
      "type": "collection",
      "id": "collection_1",
      "label": "t:labels.collection_1"
    },
    {
      "type": "text",
      "id": "collection_1_label",
      "label": "t:labels.collection_label"
    },
    {
      "type": "collection",
      "id": "collection_2",
      "label": "t:labels.collection_2"
    },
    {
      "type": "text",
      "id": "collection_2_label",
      "label": "t:labels.collection_label"
    },
    {
      "type": "collection",
      "id": "collection_3",
      "label": "t:labels.collection_3"
    },
    {
      "type": "text",
      "id": "collection_3_label",
      "label": "t:labels.collection_label"
    }
  ],
  "presets": [
    {
      "name": "t:general.featured_collections"
    }
  ]
}
{% endschema %}
